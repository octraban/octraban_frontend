# Frontend environment — copy this file to .env before running `npm run dev`
#
#   cp frontend/.env.example frontend/.env

# NOTE: most of the app calls the indexer via the relative path "/api", proxied
# to VITE_INDEXER_URL by Vite in dev (see server.proxy in vite.config.ts) and by
# nginx in the Docker image (see nginx.conf). This var itself isn't read by app
# code — it only documents what the proxy target should be.
VITE_INDEXER_URL=http://localhost:3001

# Base URL for the Sandbox's own API client (src/services/sandbox-api.ts).
# Falls back to http://localhost:3001 if unset.
VITE_API_URL=http://localhost:3001

# Soroban testnet RPC (used by the Sandbox page)
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase
VITE_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
